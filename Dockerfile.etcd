# ═══════════════════════════════════════════════════════
#  Dockerfile.etcd  –  3-node etcd cluster in one container
#
#  Uses goreman (Go process manager) to run etcd-1, etcd-2,
#  and etcd-3 on localhost within the same container.
#  Only port 2379 (etcd-1 client URL) is exposed externally.
#
#  Build: docker build -f Dockerfile.etcd -t etcd-cluster .
# ═══════════════════════════════════════════════════════

FROM golang:1.23-alpine AS builder

# Install goreman (Procfile-based process manager)
RUN go install github.com/mattn/goreman@latest


FROM alpine:3.20

# Install etcd
ENV ETCD_VERSION=v3.5.13
RUN apk add --no-cache curl bash && \
    curl -L "https://github.com/etcd-io/etcd/releases/download/${ETCD_VERSION}/etcd-${ETCD_VERSION}-linux-amd64.tar.gz" \
      | tar xz --strip-components=1 -C /usr/local/bin \
      etcd-${ETCD_VERSION}-linux-amd64/etcd \
      etcd-${ETCD_VERSION}-linux-amd64/etcdctl

COPY --from=builder /go/bin/goreman /usr/local/bin/goreman

# Create data directories
RUN mkdir -p /data/node1 /data/node2 /data/node3

# Goreman Procfile — 3-node cluster on localhost
# node1 = primary client port (2379)
# All peer communication stays on localhost (2380, 2382, 2384)
RUN cat > /Procfile <<'EOF'
node1: etcd --name node1 \
  --data-dir /data/node1 \
  --listen-client-urls http://0.0.0.0:2379 \
  --advertise-client-urls http://0.0.0.0:2379 \
  --listen-peer-urls http://0.0.0.0:2380 \
  --initial-advertise-peer-urls http://127.0.0.1:2380 \
  --initial-cluster node1=http://127.0.0.1:2380,node2=http://127.0.0.1:2382,node3=http://127.0.0.1:2384 \
  --initial-cluster-token etcd-cluster-1 \
  --initial-cluster-state new

node2: etcd --name node2 \
  --data-dir /data/node2 \
  --listen-client-urls http://0.0.0.0:2381 \
  --advertise-client-urls http://0.0.0.0:2381 \
  --listen-peer-urls http://0.0.0.0:2382 \
  --initial-advertise-peer-urls http://127.0.0.1:2382 \
  --initial-cluster node1=http://127.0.0.1:2380,node2=http://127.0.0.1:2382,node3=http://127.0.0.1:2384 \
  --initial-cluster-token etcd-cluster-1 \
  --initial-cluster-state new

node3: etcd --name node3 \
  --data-dir /data/node3 \
  --listen-client-urls http://0.0.0.0:2383 \
  --advertise-client-urls http://0.0.0.0:2383 \
  --listen-peer-urls http://0.0.0.0:2384 \
  --initial-advertise-peer-urls http://127.0.0.1:2384 \
  --initial-cluster node1=http://127.0.0.1:2380,node2=http://127.0.0.1:2382,node3=http://127.0.0.1:2384 \
  --initial-cluster-token etcd-cluster-1 \
  --initial-cluster-state new
EOF

EXPOSE 2379 2381 2383

# goreman exits when any process fails – keeps Railway happy
CMD ["goreman", "-f", "/Procfile", "start"]
