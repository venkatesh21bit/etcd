# ═══════════════════════════════════════════════════════
#  .env.example  –  copy to .env and fill in values
#
#  For local docker-compose:
#    cp .env.example .env
#
#  For running client.py directly on a laptop:
#    export $(cat .env | xargs)   and then   python client.py
# ═══════════════════════════════════════════════════════

# ── etcd connection ───────────────────────────────────
# When using docker-compose locally: ETCD_HOST=localhost
# When connecting to Railway-deployed etcd, paste the
# TCP proxy domain+port from the Railway dashboard.
ETCD_HOST=localhost
ETCD_PORT=2379

# ── PostgreSQL connection ─────────────────────────────
# docker-compose local default:
DATABASE_URL=postgresql://postgres:password@localhost:5432/etcd_demo

# Railway value example (replace with your actual URL):
# DATABASE_URL=postgresql://postgres:xxxxxx@roundhouse.proxy.rlwy.net:5432/railway

# ── Client identity ───────────────────────────────────
# Set to "client-1" on Laptop/System 1
# Set to "client-2" on Laptop/System 2
CLIENT_ID=client-1

# ── Lock configuration ────────────────────────────────
# Lease TTL in seconds — how long before an unresponsive
# leader's lock expires and another client can take over
LEASE_TTL=15

# ── Visualiser ────────────────────────────────────────
LIVE_MODE=false      # change to "true" when connecting to real etcd+PG
PORT=5000            # HTTP port for the Flask/gunicorn visualiser

# ── PostgreSQL (docker-compose only) ─────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=etcd_demo
