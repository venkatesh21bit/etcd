# ── .env for Machine 1 ────────────────────────────────────────────────────
# Copy this file to .env before running docker-compose.system1.yml

# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=venkat*2005
POSTGRES_DB=etcd

# Lease TTL in seconds (how long the lock stays alive without a keepalive)
LEASE_TTL=15
