# ── .env for Machine 2 ────────────────────────────────────────────────────
# Copy this file to .env before running docker-compose.system2.yml

# !! CHANGE THIS to Machine 1's LAN IP address !!
# On Machine 1 run:   ipconfig          (Windows)
#                  or  hostname -I | awk '{print $1}'   (Linux/macOS)
SYSTEM1_IP=192.168.1.10

# Must match the values used on Machine 1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=etcd_demo

# Lease TTL — must match Machine 1
LEASE_TTL=15
